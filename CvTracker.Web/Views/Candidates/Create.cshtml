@model CandidateCreateViewModel
@{
    ViewData["Title"] = "Upload CV";
}

<div class="page-header">
    <div>
        <h1>Upload CV</h1>
        <div class="subtitle">CV Tracking · Add a candidate and attach their résumé.</div>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to list</a>
</div>

<div class="surface-card">
    <div class="card-body">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <div class="form-group">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" placeholder="Full name" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="form-group">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" placeholder="name@email.com" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="form-group">
                <label asp-for="Phone" class="form-label"></label>
                <input asp-for="Phone" class="form-control" placeholder="Phone number" />
                <span asp-validation-for="Phone" class="text-danger small"></span>
            </div>

            <div class="form-group">
                <label asp-for="CvFile" class="form-label">CV file</label>
                <input asp-for="CvFile" type="file" class="form-control-file" />
                <small class="form-text text-muted-soft">PDF, DOC, or DOCX.</small>
                <span asp-validation-for="CvFile" class="text-danger small d-block"></span>
            </div>

            <div class="d-flex flex-wrap pt-2">
                <button type="submit" class="btn btn-primary mr-2 mb-2">Save candidate</button>
                <a asp-action="Index" class="btn btn-outline-secondary mb-2">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
