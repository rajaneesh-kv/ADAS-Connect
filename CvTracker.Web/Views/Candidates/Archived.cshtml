@model List<Candidate>
@{
    ViewData["Title"] = "Archived candidates";
}

<div class="page-header">
    <div>
        <h1>Archived</h1>
        <div class="subtitle">CV Tracking · Soft-deleted candidates. Restore to bring them back to the active list.</div>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to list</a>
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <div class="font-weight-bold text-dark mb-1">No archived candidates</div>
    </div>
}
else
{
    @foreach (var c in Model)
    {
        <div class="surface-card mb-3">
            <div class="card-body d-flex justify-content-between align-items-center flex-wrap">
                <div>
                    <div class="font-weight-bold">@c.Name</div>
                    <div class="small text-muted-soft">@c.Email · @c.Phone</div>
                </div>
                <form asp-action="Restore" method="post" asp-route-id="@c.Id" class="m-0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-primary">Restore</button>
                </form>
            </div>
        </div>
    }
}
