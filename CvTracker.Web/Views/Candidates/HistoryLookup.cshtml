@model HistoryLookupViewModel
@{
    ViewData["Title"] = "History lookup";
}

<div class="page-header">
    <div>
        <h1>History lookup</h1>
        <div class="subtitle">CV Tracking · Find candidates and see how often each stage appears in their history.</div>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to list</a>
</div>

<form method="get" class="surface-card mb-4">
    <div class="card-body py-3">
        <div class="row mb-gutter align-items-end">
            <div class="col-12 col-md-4">
                <label class="form-label mb-1">Search</label>
                <input name="search" value="@Model.Search" class="form-control" placeholder="Name, email, or phone" />
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label mb-1">Name contains</label>
                <input name="name" value="@Model.Name" class="form-control" />
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label mb-1">Email contains</label>
                <input name="email" value="@Model.Email" class="form-control" />
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label mb-1">Phone contains</label>
                <input name="phone" value="@Model.Phone" class="form-control" />
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label mb-1">History from</label>
                <input type="date" name="historyFrom" value="@Model.HistoryFrom" class="form-control" />
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label mb-1">History to</label>
                <input type="date" name="historyTo" value="@Model.HistoryTo" class="form-control" />
            </div>
            <div class="col-12 col-md-2">
                <button class="btn btn-primary btn-block" type="submit">Search</button>
            </div>
        </div>
        <div class="small text-muted-soft mb-0">If history dates are set, only candidates with a status change in that window are listed, and counts use events inside the window.</div>
    </div>
</form>

@if (!Model.Rows.Any())
{
    <div class="empty-state">
        <div class="font-weight-bold text-dark mb-1">No results</div>
        <div class="small">Try widening your search or clearing history dates.</div>
    </div>
}
else
{
    @foreach (var row in Model.Rows)
    {
        <div class="surface-card mb-3">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start flex-wrap">
                    <div>
                        <div class="font-weight-bold">@row.Name</div>
                        <div class="small text-muted-soft">@row.Email · @row.Phone</div>
                    </div>
                    <div class="text-right">
                        <div class="small text-muted-soft">Current status</div>
                        <span class="badge badge-secondary">@StatusLabels.For(row.CurrentStatus)</span>
                    </div>
                </div>
                <div class="row mt-3">
                    <div class="col-12 col-md-4">
                        <div class="small text-muted-soft">Interviews attended (recorded)</div>
                        <div class="h5 mb-0">@row.InterviewsAttended</div>
                    </div>
                </div>
                <div class="section-title mt-3">History counts</div>
                <div class="row">
                    @foreach (var kv in row.HistoryCounts.OrderBy(k => k.Key))
                    {
                        <div class="col-6 col-md-4 col-lg-2 mb-2">
                            <div class="summary-card mb-0 py-2">
                                <div class="small text-muted-soft">@StatusLabels.For(kv.Key)</div>
                                <div class="count">@kv.Value</div>
                            </div>
                        </div>
                    }
                </div>
                <div class="mt-3">
                    <a asp-action="Details" asp-route-id="@row.CandidateId" class="btn btn-sm btn-outline-primary">Open profile</a>
                </div>
            </div>
        </div>
    }
}
