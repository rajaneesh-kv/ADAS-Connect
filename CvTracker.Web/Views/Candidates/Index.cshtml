@model CandidatesIndexViewModel
@{
    ViewData["Title"] = "Candidates";
}

<div class="page-header">
    <div>
        <h1>Candidates</h1>
        <div class="subtitle">CV Tracking · Search, filter by contact and dates, then open a profile.</div>
    </div>
    <div class="d-flex flex-wrap">
        <a asp-action="HistoryLookup" class="btn btn-outline-primary mr-2 mb-2">History lookup</a>
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Archived" class="btn btn-outline-secondary mb-2">Archived</a>
        }
        <a asp-action="Create" class="btn btn-primary ml-md-2 mb-2">Upload CV</a>
    </div>
</div>

<form method="get" class="surface-card mb-4">
    <div class="card-body py-3">
        <div class="row mb-gutter align-items-end">
            <div class="col-12 col-md-4">
                <label class="form-label mb-1">Quick search</label>
                <input name="search" value="@Model.Search" class="form-control" placeholder="Name, email, or phone" />
            </div>
            <div class="col-12 col-md-3">
                <label class="form-label mb-1">Status</label>
                <select name="status" class="custom-select" asp-for="Status" asp-items="Html.GetEnumSelectList<CandidateStatus>()">
                    <option value="">All statuses</option>
                </select>
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label mb-1">Added from</label>
                <input type="date" name="dateFrom" value="@Model.DateFrom" class="form-control" />
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label mb-1">Added to</label>
                <input type="date" name="dateTo" value="@Model.DateTo" class="form-control" />
            </div>
            <div class="col-12 col-md-1">
                <button class="btn btn-primary btn-block" type="submit">Apply</button>
            </div>
        </div>
        <div class="small text-muted-soft mb-2">Optional filters (combined with quick search)</div>
        <div class="row mb-gutter align-items-end">
            <div class="col-12 col-md-4">
                <label class="form-label mb-1">Name contains</label>
                <input name="name" value="@Model.Name" class="form-control" placeholder="Part of name" />
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label mb-1">Email contains</label>
                <input name="email" value="@Model.Email" class="form-control" placeholder="Part of email" />
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label mb-1">Phone contains</label>
                <input name="phone" value="@Model.Phone" class="form-control" placeholder="Digits / number" />
            </div>
        </div>
        <div class="d-flex flex-wrap">
            <a asp-action="Index" class="btn btn-link px-0">Clear all filters</a>
        </div>
    </div>
</form>

@if (!Model.Candidates.Any())
{
    <div class="empty-state">
        <div class="font-weight-bold text-dark mb-1">No candidates match</div>
        <div class="small">Try clearing filters or upload a new CV.</div>
    </div>
}
else
{
    @foreach (var candidate in Model.Candidates)
    {
        string badgeClass;
        switch (candidate.Status)
        {
            case CandidateStatus.NotCalled:
                badgeClass = "badge-status--notcalled";
                break;
            case CandidateStatus.Called:
                badgeClass = "badge-status--called";
                break;
            case CandidateStatus.Interviewed:
                badgeClass = "badge-status--interviewed";
                break;
            case CandidateStatus.Shortlisted:
                badgeClass = "badge-status--shortlisted";
                break;
            case CandidateStatus.Selected:
                badgeClass = "badge-status--selected";
                break;
            default:
                badgeClass = "badge-status--notcalled";
                break;
        }
        <div class="candidate-card">
            <div class="d-flex justify-content-between align-items-start">
                <div class="pr-3">
                    <div class="name">@candidate.Name</div>
                    <div class="small text-muted-soft mt-1">@candidate.Email</div>
                    <div class="small text-muted-soft">@candidate.Phone</div>
                    <div class="small text-muted-soft mt-1">Added @candidate.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</div>
                </div>
                <span class="badge-status @badgeClass">@StatusLabels.For(candidate.Status)</span>
            </div>
            <div class="d-flex justify-content-between align-items-center mt-3">
                <span class="small text-muted-soft">Interviews attended <strong class="text-dark">@candidate.InterviewCount</strong></span>
                <a asp-action="Details" asp-route-id="@candidate.Id" class="btn btn-sm btn-outline-primary">Open</a>
            </div>
        </div>
    }
}
